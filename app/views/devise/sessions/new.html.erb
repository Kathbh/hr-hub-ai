<div class="login-container">
  <div class="login-card">

    <h2 class="login-title">Welcome to HR Hub</h2>
    <p class="login-subtitle">Sign in to continue</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-group">
        <%= f.input :email,
                    label: "Email",
                    input_html: { class: "input-field" } %>
      </div>

      <div class="form-group">
        <%= f.input :password,
                    label: "Password",
                    input_html: { class: "input-field" } %>
      </div>

      <div class="form-group checkbox-group">
        <%= f.input :remember_me, as: :boolean, label: "Remember me" if devise_mapping.rememberable? %>
      </div>

      <div class="actions">
        <%= f.button :submit, "Log in", class: "login-button" %>
      </div>

    <% end %>

    <div class="login-links">
      <%= render "sessions/shared/links" %>
    </div>
  </div>
</div>
