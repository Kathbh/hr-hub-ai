<h1>Welcome, <%= @employee.first_name %>!</h1>

<h2>Your Profile</h2>
<p><strong>Name:</strong> <%= @employee.full_name %></p>
<p><strong>Job Title:</strong> <%= @employee.job_title %></p>
<p><strong>Department:</strong> <%= @employee.department %></p>
<p><strong>Country:</strong> <%= @employee.country %></p>

<hr>

<h2>Your Cases</h2>
<% @cases.each do |c| %>
  <p>
    <strong><%= c.category %></strong> — <%= c.status %><br>
    <%= c.description %>
  </p>
<% end %>

<hr>

<h2>Your Messages</h2>
<% @messages.each do |m| %>
  <p>
    <strong><%= m.sender %>:</strong> <%= m.content %>
  </p>
<% end %>

<hr>

<h2>Policies</h2>
<% @policies.each do |p| %>
  <p><strong><%= p.title %></strong> — <%= p.category %></p>
<% end %>

