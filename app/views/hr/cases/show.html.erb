<turbo-frame id="dynamic-panels">

  <turbo-frame id="employee_panel">
    <div class="employee-panel">
      <h2><%= @employee.full_name %></h2>

      <p><strong>Role:</strong> <%= @employee.role %></p>
      <p><strong>Country:</strong> <%= @employee.country %></p>
      <p><strong>Email:</strong> <%= @employee.email %></p>

      <hr>

      <h3>Case Details</h3>
      <p><strong>Category:</strong> <%= @case.category %></p>
      <p><strong>Description:</strong> <%= @case.description %></p>

      <h3>Status: <%= @case.status.humanize %></h3>
      <div class="status-buttons">
        <%= button_to "Open",
            update_status_hr_case_path(@case, status: "open"),
            method: :patch,
            data: { turbo_frame: "dynamic-panels" },
            class: "status-btn open" %>

        <%= button_to "On Hold",
            update_status_hr_case_path(@case, status: "on_hold"),
            method: :patch,
            data: { turbo_frame: "dynamic-panels" },
            class: "status-btn on-hold" %>

        <%= button_to "Resolved",
            update_status_hr_case_path(@case, status: "resolved"),
            method: :patch,
            data: { turbo_frame: "dynamic-panels" },
            class: "status-btn resolved" %>

        <%= button_to "Cancelled",
            update_status_hr_case_path(@case, status: "cancelled"),
            method: :patch,
            data: { turbo_frame: "dynamic-panels" },
            class: "status-btn cancelled" %>
      </div>
    </div>
  </turbo-frame>

  <turbo-frame id="case_messages_panel">
    <div class="messages-panel">
      <h2>Messages</h2>

      <% @messages.each do |m| %>
        <div class="message-item">
          <strong><%= m.sender.capitalize %>:</strong> <%= m.content %></p>
          <p class="timestamp"><%= m.created_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
    </div>

    <%= form_with url: hr_case_messages_path(@case), method: :post, data: { turbo_frame: "case_messages_panel" } do |f| %>
      <div class="message-form">
        <%= f.text_area :content, placeholder: "Write a message…" %>
        <%= f.submit "Send", class: "btn-send" %>
      </div>
    <% end %>
  </turbo-frame>
</turbo-frame>
