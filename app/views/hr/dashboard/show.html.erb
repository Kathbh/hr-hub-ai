<div class="hr-dashboard-grid">

  <!-- LEFT TOP: CASE LIST -->
  <div class="cases-panel">
    <h2>Cases</h2>
    <% @cases.each do |c| %>
      <div class="case-item">
        <%= link_to "Case ##{c.id} — #{c.category}",
            hr_case_path(c),
            data: { turbo_frame: "dynamic-panels" } %>
      </div>
    <% end %>
  </div>

  <!-- RIGHT SIDE: EMPLOYEE + MESSAGES (Turbo needs them grouped) -->
  <turbo-frame id="dynamic-panels" src="">

    <!-- EMPLOYEE PROFILE -->
    <turbo-frame id="employee_panel">
      <div class="employee-panel">
        <h2>Employee Profile</h2>
        <p>Select a case to view employee details.</p>
      </div>
    </turbo-frame>

    <!-- MESSAGES -->
    <turbo-frame id="messages_panel">
      <div class="messages-panel">
        <h2>Messages</h2>
        <p>Select a case to view messages.</p>
      </div>
    </turbo-frame>
  </turbo-frame>

  <!-- LEFT BOTTOM: POLICIES -->
  <div class="policies-panel">
    <h2>Policies</h2>
    <% @policies.each do |p| %>
      <p><%= p.title %></p>
    <% end %>
  </div>

  <!-- RIGHT BOTTOM: HR NOTES -->
  <div class="notes-panel">
    <h2>HR Notes</h2>
    <textarea rows="6" placeholder="Write internal notes here..."></textarea>
  </div>

</div>

<!-- Floating AI button -->
<%= link_to "🤖", chat_path, class: "ai-button" %>
