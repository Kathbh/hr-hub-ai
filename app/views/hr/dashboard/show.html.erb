<div class="hr-dashboard-grid">

  <!-- LEFT TOP: CASE LIST -->
  <div class="cases-panel">
    <h2>Cases</h2>
    <% @cases.each do |c| %>
      <div class="case-item">
        <%= link_to "Case ##{c.id} — #{c.category}",
            hr_case_path(c),
            data: { turbo_frame: "dynamic-panels" } %>
      </div>
    <% end %>
  </div>

  <!-- RIGHT SIDE: EMPLOYEE + MESSAGES (Turbo needs them grouped) -->
  <turbo-frame id="dynamic-panels" src="">

    <!-- EMPLOYEE PROFILE -->
    <turbo-frame id="employee_panel">
      <div class="employee-panel">
        <h2>Employee Profile</h2>
        <p>Select a case to view employee details.</p>
      </div>
    </turbo-frame>

    <!-- MESSAGES -->
    <turbo-frame id="messages_panel">
      <div class="messages-panel">
        <h2>Messages</h2>
        <p>Select a case to view messages.</p>
      </div>
    </turbo-frame>
  </turbo-frame>

  <!-- LEFT BOTTOM: POLICIES -->
  <div class="policies-panel">
    <h2>Policies</h2>
    <% @policies.each do |p| %>
      <p><%= p.title %></p>
    <% end %>
  </div>

  <!-- RIGHT BOTTOM: HR NOTES -->
  <div class="notes-panel">
    <h2>HR Notes</h2>
    <textarea rows="6" placeholder="Write internal notes here..."></textarea>
  </div>

    <!-- RIGHT SIDE: AI PANEL -->
  <div id="ai-panel" class="ai-side-panel" data-turbo="false">
    <button id="close-ai-panel" class="close-ai-btn">✖</button>

    <h2>AI Assistant</h2>

    <%= form_with url: ai_path, method: :post, data: { turbo: false } do |f| %>
      <%= f.text_area :prompt, rows: 4, placeholder: "Ask the AI…" %>
      <%= f.submit "Generate", class: "ai-generate-btn" %>
    <% end %>

    <% if @ai_response.present? %>
      <div class="ai-response-box">
        <p><%= @ai_response %></p>
      </div>
    <% end %>
  </div>

  <button class="floating-ai-button">🤖</button>
</div>



<script>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.querySelector(".floating-ai-button")
    const panel = document.querySelector("#ai-panel")
    const closeBtn = document.querySelector("#close-ai-panel")

    // 1. Open when clicking the button
    button.addEventListener("click", (event) => {
      event.preventDefault()
      panel.style.display = "block"
      panel.scrollIntoView({ behavior: "smooth" })
    })

    // 2. Close when clicking the X
    closeBtn.addEventListener("click", () => {
      panel.style.display = "none"
    })

    // 3. If AI responded, open automatically
    const aiResponseExists = "<%= @ai_response.present? %>" === "true"
    if (aiResponseExists) {
      panel.style.display = "block"
      panel.scrollIntoView({ behavior: "smooth" })
    }
  })
</script>
