<style>
  body {
    background: linear-gradient(135deg, #ffd6f2 0%, #d6e8ff 100%);
    font-family: "Inter", sans-serif;
    height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-container {
    text-align: center;
    background: white;
    padding: 55px 45px;
    border-radius: 28px;
    box-shadow: 0 12px 35px rgba(0,0,0,0.12);
    max-width: 650px;
    width: 90%;
  }

  h1 {
    font-size: 2.6rem;
    font-weight: 700;
    color: #ff4fa3;
    margin-bottom: 18px;
  }

  p {
    font-size: 1.25rem;
    color: #444;
    margin-bottom: 40px;
    line-height: 1.5;
  }

  .start-btn {
    background: linear-gradient(135deg, #ff4fa3, #6ea8ff);
    border: none;
    padding: 16px 40px;
    color: white;
    font-size: 1.25rem;
    border-radius: 14px;
    cursor: pointer;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .start-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.18);
  }
</style>

<div class="home-container">
  <h1>Welcome to Your HR Hub</h1>
  <p>All the Human Resources support you need, in one place.</p>

  <%= link_to "Start Here", new_user_session_path, class: "start-btn" %>
</div>
