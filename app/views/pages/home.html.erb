<style>
  body {
    background: linear-gradient(135deg, #ffd6f2 0%, #d6e8ff 100%);
    font-family: "Inter", sans-serif;
    height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-container {
    text-align: center;
    background: white;
    padding: 50px 40px;
    border-radius: 25px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    max-width: 600px;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #ff4fa3;
    margin-bottom: 15px;
  }

  p {
    font-size: 1.2rem;
    color: #555;
    margin-bottom: 35px;
  }

  .start-btn {
    background: linear-gradient(135deg, #ff4fa3, #6ea8ff);
    border: none;
    padding: 15px 35px;
    color: white;
    font-size: 1.2rem;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .start-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  }
</style>

<div class="home-container">
  <h1>Welcome to Your HR Global Hub</h1>
  <p>Your personalized HR companion, is ready to help you anytime.</p>

  <%= link_to "Start Chatting", chat_path, class: "start-btn" %>
</div>
